{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist/server",
    "rootDir": "./server",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules"]
}
