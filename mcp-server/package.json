{
  "name": "clientflow-mcp",
  "version": "0.1.0",
  "description": "Local MCP (Model Context Protocol) server that wraps the Client Flow external REST API so an AI agent can list, read, create, update, and delete records through a scoped API key.",
  "type": "module",
  "private": true,
  "bin": {
    "clientflow-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3"
  }
}
